---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import AffiliateDisclosure from '../components/affiliate/AffiliateDisclosure.astro';
import ProductReviewCard from '../components/affiliate/ProductReviewCard.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { readData } from '../lib/readData';
import GptContentAd from '../plugins/gpt-ads/GptContentAd.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const formattedUpdatedDate = post.data.updatedDate?.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'reviews': 'Reviews',
  'comparativos': 'Comparativos',
  'guias': 'Guias',
  'birdwatching': 'Birdwatching',
  'astronomia': 'Astronomia',
  'dicas': 'Dicas',
};

const badgeLabels: Record<string, string> = {
  'top-pick': 'Melhor no Geral',
  'editor-choice': 'Escolha do Editor',
  'best-value': 'Melhor Custo-Benefício',
  'budget': 'Mais Barato',
  'premium': 'Premium',
  'best-for-birds': 'Melhor para Aves',
  'lightweight': 'Mais Leve',
  'compact': 'Compacto',
};

const products = post.data.products || [];
const featuredProduct = products.find((p) => p.featured) || products[0] || null;
const hasProducts = products.length > 0;
const hasLegacyLink = !hasProducts && !!post.data.affiliateLink;

const allAuthors: any[] = readData('authors.json') || [];
const siteConfig: any = readData('siteConfig.json') || {};
const postAuthor = allAuthors.find((a: any) => a.name === post.data.author) || allAuthors[0] || null;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: categoryLabels[post.data.category] || post.data.category, url: `/blog` },
];
---

<BaseLayout
  title={post.data.title}
  seoTitle={post.data.seoTitle}
  description={post.data.description}
  image={post.data.image}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  rating={post.data.rating}
  tags={post.data.tags}
  products={products}
  breadcrumbs={breadcrumbs}
  faqs={post.data.faqs}
>
  <article class="post">
    <header class="post-header">
      <div class="post-header-bg"></div>
      <div class="container post-header-inner">
        <nav class="post-breadcrumb" aria-label="Breadcrumb">
          {breadcrumbs.map((crumb, i) => (
            <>
              {i > 0 && <span class="post-breadcrumb-sep">/</span>}
              {i < breadcrumbs.length - 1 ? (
                <a href={crumb.url}>{crumb.name}</a>
              ) : (
                <span>{crumb.name}</span>
              )}
            </>
          ))}
        </nav>

        <div class="post-meta">
          <span class="post-category">{categoryLabels[post.data.category] || post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
          {formattedUpdatedDate && (
            <>
              <span class="post-meta-dot">·</span>
              <span class="post-updated">Atualizado: {formattedUpdatedDate}</span>
            </>
          )}
          <span class="post-meta-dot">·</span>
          <span>Por {post.data.author}</span>
        </div>

        <h1 class="post-title">{post.data.title}</h1>
      </div>
    </header>

    {post.data.image && (
      <div class="container">
        <div class="post-image">
          <img src={post.data.image} alt={post.data.imageAlt || post.data.title} />
        </div>
      </div>
    )}

    <div class="container">
      {post.data.showDisclosure && (hasProducts || hasLegacyLink) && (
        <div class="post-disclosure">
          <AffiliateDisclosure variant="inline" />
        </div>
      )}

      <div class:list={['post-layout', { 'post-layout-sidebar': post.data.showToc || featuredProduct }]}>
        {/* Sidebar */}
        {post.data.showToc && (
          <aside class="post-sidebar">
            <TableOfContents headings={headings} variant="desktop" />
          </aside>
        )}

        {/* Main content */}
        <div class="post-content-area">
          {/* Mobile TOC */}
          {post.data.showToc && <TableOfContents headings={headings} variant="mobile" />}

          {/* 1. Intro (from frontmatter — renders before product cards) */}
          {post.data.intro && (
            <div class="post-intro" set:html={post.data.intro} />
          )}

          {/* 2. Products heading + Quick-picks list */}
          {products.length > 0 && post.data.productsHeading && (
            <h2 class="post-products-heading">{post.data.productsHeading}</h2>
          )}
          {products.length > 0 && (
            <div class="quick-picks">
              <div class="quick-picks__header">
                <span class="quick-picks__col-produto">Produto</span>
                <span class="quick-picks__col-destaques">Destaques</span>
              </div>
              <ol class="quick-picks__list">
                {products.map((product, i) => (
                  <li class="quick-picks__item">
                    <div class="quick-picks__row">
                      <a href={`#review-${i + 1}`} class="quick-picks__info">
                        <span class="quick-picks__num">{i + 1}</span>
                        {product.image
                          ? <img src={product.image} alt={product.name} class="quick-picks__img" loading="lazy" />
                          : <span class="quick-picks__img-placeholder" />
                        }
                        <span class="quick-picks__name">
                          {product.name}
                          {product.badge && (
                            <span class="quick-picks__badge">{badgeLabels[product.badge] ?? product.badge.replace(/-/g, ' ')}</span>
                          )}
                        </span>
                      </a>
                      <div class="quick-picks__actions">
                        <a href={product.affiliateLink} class="qp-btn qp-btn--amazon" target="_blank" rel="sponsored noopener">
                          Ver na Amazon
                        </a>
                        <a href={product.affiliateLink} class="qp-btn qp-btn--ml" target="_blank" rel="sponsored noopener">
                          Ver no Mercado Livre
                        </a>
                      </div>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          )}

          {/* 3. Product Review Cards (all products) */}
          {products.length > 0 && (
            <div class="post-products-section">
              <div class="post-products-header">
                <p class="post-products-title">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
                  {products.length === 1 ? 'Nosso Veredito' : `Os ${products.length} Melhores — Análise Completa`}
                </p>
                <p class="post-products-subtitle">Prós, contras e preços reais de cada produto avaliado.</p>
              </div>
              <div class:list={['post-products-grid', products.length === 1 && 'post-products-grid--single']}>
                {products.map((product, i) => (
                  <ProductReviewCard
                    name={product.name}
                    description={product.description}
                    review={product.review}
                    price={product.price}
                    originalPrice={product.originalPrice}
                    rating={product.rating}
                    affiliateLink={product.affiliateLink}
                    mlLink={product.mlLink}
                    store={product.store}
                    image={product.image}
                    badge={product.badge}
                    pros={product.pros}
                    cons={product.cons}
                    index={i + 1}
                  />
                ))}
              </div>
            </div>
          )}

          {/* Content 1 — antes do corpo do artigo */}
          <GptContentAd num={1} />

          {/* 4. Guide content (article body markdown — renders after product cards) */}
          <div class="post-content">
            <Content />
          </div>

          {/* Content 2 — após o corpo do artigo (lazy) */}
          <GptContentAd num={2} />

          {/* 5. FAQ */}
          {post.data.faqs && post.data.faqs.length > 0 && (
            <section class="post-faq-section" id="faq">
              <h2 class="post-faq-title">Perguntas Frequentes</h2>
              <div class="post-faq-list">
                {post.data.faqs.map((faq) => (
                  <details class="post-faq-item">
                    <summary class="post-faq-q"><h3 class="post-faq-h3">{faq.q}</h3></summary>
                    <div class="post-faq-a">{faq.a}</div>
                  </details>
                ))}
              </div>
            </section>
          )}

          {/* Content 3 — após FAQ */}
          <GptContentAd num={3} />

          {/* 6. Conclusão */}
          {post.data.conclusion && (
            <div class="post-conclusion">
              <h2 class="post-conclusion-title">{post.data.conclusionHeading || 'Conclusão'}</h2>
              {post.data.conclusion.split(/\n\n+/).map((p) => <p>{p}</p>)}
            </div>
          )}

          {/* Content 4 — após conclusão */}
          <GptContentAd num={4} />

          {/* 7. Especialistas */}
          {postAuthor && (
            <section class="post-experts" id="especialistas">
              <h2 class="post-experts-title">Conheça nossos especialistas</h2>
              <div class="post-experts-list">
                <div class="post-expert-card">
                  {postAuthor.avatar && (
                    <img src={postAuthor.avatar} alt={postAuthor.name} class="post-expert-avatar" />
                  )}
                  <div class="post-expert-info">
                    <h3 class="post-expert-name">{postAuthor.name}</h3>
                    {postAuthor.jobTitle && <p class="post-expert-role">{postAuthor.jobTitle}</p>}
                    {postAuthor.bio && <p class="post-expert-bio">{postAuthor.bio}</p>}
                  </div>
                </div>
                <div class="post-expert-card">
                  <div class="post-expert-info">
                    <h3 class="post-expert-name">{siteConfig.name}</h3>
                    {siteConfig.description && <p class="post-expert-bio">{siteConfig.description}</p>}
                  </div>
                </div>
              </div>
            </section>
          )}

          {/* Bottom CTA: legacy fallback */}
          {hasLegacyLink && (
            <div class="post-affiliate-cta">
              <div class="post-affiliate-badge">Recomendação</div>
              <p class="post-affiliate-text">Gostou deste produto? Confira o melhor preço:</p>
              <a href={post.data.affiliateLink} class="btn btn-secondary" target="_blank" rel="sponsored noopener">
                Ver Produto
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/></svg>
              </a>
            </div>
          )}
        </div>
      </div>

      {/* Related Posts */}
      <RelatedPosts currentCategory={post.data.category} currentSlug={post.id} />
    </div>

    <nav class="container post-nav">
      <div class="post-nav-line"></div>
      <a href="/blog" class="btn btn-outline">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Voltar ao Blog
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  /* Header */
  .post-header {
    position: relative;
    padding: calc(var(--navbar-height) + var(--space-3xl)) 0 var(--space-3xl);
    overflow: hidden;
  }

  .post-header-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 30% 40%, rgba(216, 243, 220, 0.3) 0%, transparent 70%),
      radial-gradient(ellipse 50% 60% at 80% 60%, rgba(245, 230, 163, 0.1) 0%, transparent 60%),
      var(--color-bg-warm);
    z-index: -1;
  }

  .post-header-inner {
    max-width: var(--container-narrow);
  }

  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--fs-xs);
    color: var(--color-text-faint);
    margin-bottom: var(--space-2xl);
    letter-spacing: var(--ls-wide);
  }

  .post-breadcrumb a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .post-breadcrumb a:hover { color: var(--color-primary); }
  .post-breadcrumb-sep { opacity: 0.3; }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .post-meta-dot { opacity: 0.3; }

  .post-updated {
    font-style: italic;
    color: var(--color-primary-light);
  }

  .post-category {
    padding: 0.3rem 0.85rem;
    background: var(--color-primary-surface);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    border: 1px solid var(--color-primary-lighter);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: var(--fs-5xl);
    font-weight: var(--fw-extrabold);
    line-height: var(--lh-tight);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-xl);
  }

  .post-description {
    font-size: var(--fs-lg);
    color: var(--color-text-secondary);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-xl);
    font-weight: var(--fw-light);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .post-tag {
    font-size: var(--fs-sm);
    color: var(--color-primary-light);
    font-weight: var(--fw-medium);
  }

  /* Featured image */
  .post-image {
    max-width: var(--container-narrow);
    margin: 0 auto;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    margin-top: calc(-1 * var(--space-xl));
    margin-bottom: var(--space-3xl);
    border: 1px solid var(--color-border-light);
  }

  .post-image img { width: 100%; height: auto; }

  /* Disclosure */
  .post-disclosure {
    max-width: var(--container-narrow);
    margin: 0 auto var(--space-lg);
  }

  /* Layout with sidebar */
  .post-layout {
    max-width: var(--container-narrow);
    margin: 0 auto;
  }

  @media (min-width: 1280px) {
    .post-layout-sidebar {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: var(--space-3xl);
      max-width: 100%;
    }

    .post-layout-sidebar .post-content-area {
      max-width: var(--container-narrow);
    }
  }

  /* Sidebar */
  .post-sidebar {
    display: none;
  }

  @media (min-width: 1280px) {
    .post-sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-2xl);
      padding-top: var(--space-xl);
    }
  }

  .sidebar-product {
    margin-top: var(--space-md);
  }

  /* Content area */
  .post-content-area {
    min-width: 0;
  }

  /* Quick-picks list */
  .quick-picks {
    margin: var(--space-xl) 0 var(--space-2xl);
    border: 1.5px solid var(--color-border-light);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: #fff;
  }

  .quick-picks__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1.25rem;
    background: var(--color-bg-cool);
    border-bottom: 1px solid var(--color-border-light);
  }

  .quick-picks__col-produto,
  .quick-picks__col-destaques {
    font-size: 0.68rem;
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    color: var(--color-text-muted);
  }

  .quick-picks__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .quick-picks__item + .quick-picks__item {
    border-top: 1px solid var(--color-border-light);
  }

  .quick-picks__row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.25rem;
    transition: background var(--transition-fast);
  }

  .quick-picks__row:hover {
    background: var(--color-bg-cool);
  }

  .quick-picks__info {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex: 1;
    min-width: 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .quick-picks__actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .quick-picks__num {
    flex-shrink: 0;
    width: 1.4rem;
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    color: var(--color-text-faint);
    text-align: right;
  }

  .quick-picks__img {
    width: 72px;
    height: 72px;
    object-fit: contain;
    border-radius: var(--radius-md);
    background: var(--color-bg-cool);
    flex-shrink: 0;
    padding: 3px;
  }

  .quick-picks__img-placeholder {
    width: 72px;
    height: 72px;
    background: var(--color-bg-cool);
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .quick-picks__name {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    line-height: var(--lh-snug);
    min-width: 0;
  }

  .quick-picks__badge {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: var(--fw-semibold);
    text-transform: capitalize;
    color: var(--color-primary);
    background: var(--color-primary-surface);
    border: 1px solid var(--color-primary-lighter);
    border-radius: var(--radius-full);
    padding: 0.15rem 0.55rem;
    width: fit-content;
  }

  .qp-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: var(--fw-semibold);
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .qp-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .qp-btn--amazon {
    background: #ff9900;
    color: #111;
    border: 1px solid #e88800;
  }

  .qp-btn--ml {
    background: #fff159;
    color: #333;
    border: 1px solid #e8dc3e;
  }

  /* Quick-picks mobile */
  @media (max-width: 599px) {
    .quick-picks__col-destaques {
      display: none;
    }

    .quick-picks__row {
      flex-wrap: wrap;
      padding: 0.75rem 1rem;
      gap: 0.5rem;
    }

    .quick-picks__info {
      width: 100%;
    }

    .quick-picks__actions {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.4rem;
      padding-left: calc(1.4rem + 36px + 1.35rem);
    }

    .qp-btn {
      font-size: 0.68rem;
      padding: 0.4rem 0.5rem;
      justify-content: center;
      text-align: center;
    }

    .quick-picks__img {
      width: 56px;
      height: 56px;
    }

    .quick-picks__img-placeholder {
      width: 56px;
      height: 56px;
    }

    .quick-picks__name {
      font-size: 0.8rem;
    }
  }

  .post-products-heading {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin: var(--space-3xl) 0 var(--space-xl);
  }

  /* Intro section (set:html — needs :global for injected HTML) */
  .post-intro {
    padding: var(--space-xl) 0 0;
  }

  .post-intro :global(p) {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-lg);
    color: var(--color-text-secondary);
    font-weight: var(--fw-light);
  }

  .post-intro :global(strong) {
    color: var(--color-text);
    font-weight: var(--fw-semibold);
  }

  .post-intro :global(.eeat-box) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem 1.1rem;
    background: #fdf6e3;
    border: 1px solid #e6d98a;
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-md);
    margin: var(--space-lg) 0;
    font-size: var(--fs-sm);
    color: #6b4f12;
    line-height: var(--lh-relaxed);
  }

  /* Content prose */
  .post-content {
    padding: var(--space-2xl) 0;
  }

  .post-content :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--fs-2xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border-light);
  }

  .post-content :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-tight);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .post-content :global(p) {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-lg);
    color: var(--color-text-secondary);
    font-weight: var(--fw-light);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .post-content :global(li) {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-sm);
    color: var(--color-text-secondary);
    list-style: disc;
    font-weight: var(--fw-light);
  }

  .post-content :global(ol li) { list-style: decimal; }

